  &lt;!-- Background Shapes --&gt;
  &lt;div class="bg-shape shape-1"&gt;&lt;/div&gt;
  &lt;div class="bg-shape shape-2"&gt;&lt;/div&gt;

  &lt;div class="pp-container"&gt;

    &lt;!-- LEFT SIDE CONTENT --&gt;
    &lt;div class="pp-left"&gt;

      &lt;h1&gt;
        Plan Smarter,
        &lt;span class="highlight"&gt;Manufacture Faster&lt;/span&gt;
      &lt;/h1&gt;

      &lt;p&gt;
        Gain complete control over production schedules,
        reduce downtime, eliminate bottlenecks, and
        maximize cable manufacturing efficiency.
      &lt;/p&gt;

      &lt;div class="pp-buttons"&gt;
        &lt;button class="btn-primary"&gt;Request Demo&lt;/button&gt;
        
      &lt;/div&gt;

      &lt;div class="pp-stats"&gt;
        &lt;div class="stat"&gt;
          &lt;h3&gt;30%&lt;/h3&gt;
          &lt;span&gt;Less Downtime&lt;/span&gt;
        &lt;/div&gt;
        &lt;div class="stat"&gt;
          &lt;h3&gt;25%&lt;/h3&gt;
          &lt;span&gt;Faster Delivery&lt;/span&gt;
        &lt;/div&gt;
        &lt;div class="stat"&gt;
          &lt;h3&gt;Real-Time&lt;/h3&gt;
          &lt;span&gt;Machine Visibility&lt;/span&gt;
        &lt;/div&gt;
      &lt;/div&gt;

    &lt;/div&gt;

    &lt;!-- RIGHT SIDE DASHBOARD MOCK --&gt;
    &lt;div class="pp-right"&gt;

      &lt;div class="dashboard-card"&gt;
        &lt;div class="card-header"&gt;Production Dashboard&lt;/div&gt;

        &lt;div class="chart-area"&gt;&lt;/div&gt;

        &lt;div class="mini-cards"&gt;
          &lt;div class="mini-card purple"&gt;&lt;/div&gt;
          &lt;div class="mini-card orange"&gt;&lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;

    &lt;/div&gt;

  &lt;/div&gt;
&lt;/section&gt;



&lt;section class="features-section"&gt;

  &lt;div class="section-bg"&gt;&lt;/div&gt;

  &lt;div class="features-container"&gt;

    &lt;h2&gt;Smart Production Capabilities&lt;/h2&gt;
    &lt;p class="section-subtitle"&gt;
      Powerful tools designed for modern cable manufacturers.
    &lt;/p&gt;

    &lt;div class="features-grid"&gt;

      &lt;div class="feature-card"&gt;
        &lt;div class="icon purple"&gt;&lt;/div&gt;
        &lt;h3&gt;Advanced Scheduling&lt;/h3&gt;
        &lt;p&gt;
          Automatically optimize production schedules based on
          machine load and workforce availability.
        &lt;/p&gt;
      &lt;/div&gt;

      &lt;div class="feature-card"&gt;
        &lt;div class="icon orange"&gt;&lt;/div&gt;
        &lt;h3&gt;Capacity Planning&lt;/h3&gt;
        &lt;p&gt;
          Prevent bottlenecks before they happen with predictive
          capacity insights.
        &lt;/p&gt;
      &lt;/div&gt;

      &lt;div class="feature-card"&gt;
        &lt;div class="icon blue"&gt;&lt;/div&gt;
        &lt;h3&gt;Order Integration&lt;/h3&gt;
        &lt;p&gt;
          Align production batches directly with confirmed sales
          orders for accurate delivery.
        &lt;/p&gt;
      &lt;/div&gt;

    &lt;/div&gt;

  &lt;/div&gt;
&lt;/section&gt;
/* ================= HERO SECTION ================= */

.pp-hero {
  position: relative;
  padding: 120px 8%;
  background: linear-gradient(135deg, #f6f7fb, #eef0ff);
  overflow: hidden;
}

.pp-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 60px;
  position: relative;
  z-index: 2;
}

/* LEFT SIDE */

.pp-left {
  max-width: 550px;
}

.pp-left h1 {
  font-size: 58px;
  font-weight: 800;
  line-height: 1.2;
  color: #222;
}

.highlight {
  color: #7b4bb7;
}

.pp-left p {
  margin: 25px 0 35px;
  font-size: 18px;
  color: #555;
  line-height: 1.6;
}

/* BUTTONS */

.pp-buttons {
  display: flex;
  gap: 16px;
  margin-bottom: 40px;
}

.btn-primary {
  background: #7b4bb7;
  color: white;
  border: none;
  padding: 14px 28px;
  border-radius: 10px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s ease;
}

.btn-primary:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(123,75,183,0.3);
}

.btn-outline {
  background: white;
  border: 2px solid #7b4bb7;
  color: #7b4bb7;
  padding: 12px 28px;
  border-radius: 10px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s ease;
}

.btn-outline:hover {
  background: #7b4bb7;
  color: white;
}

/* STATS */

.pp-stats {
  display: flex;
  gap: 40px;
}

.stat h3 {
  font-size: 28px;
  color: #7b4bb7;
}

.stat span {
  font-size: 14px;
  color: #777;
}

/* RIGHT DASHBOARD */

.dashboard-card {
  width: 420px;
  background: white;
  padding: 25px;
  border-radius: 20px;
  box-shadow: 0 30px 60px rgba(0,0,0,0.1);
  transform: rotate(2deg);
}

.card-header {
  font-weight: 600;
  margin-bottom: 20px;
}

.chart-area {
  height: 140px;
  background: linear-gradient(135deg, #7b4bb7, #f4a621);
  border-radius: 15px;
  margin-bottom: 20px;
}

.mini-cards {
  display: flex;
  gap: 10px;
}

.mini-card {
  flex: 1;
  height: 60px;
  border-radius: 10px;
}

.mini-card.purple {
  background: #7b4bb7;
}

.mini-card.orange {
  background: #f4a621;
}

/* BACKGROUND SHAPES */

.bg-shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.3;
}

.shape-1 {
  width: 350px;
  height: 350px;
  background: #7b4bb7;
  top: -120px;
  left: -120px;
}

.shape-2 {
  width: 400px;
  height: 400px;
  background: #f4a621;
  bottom: -150px;
  right: -150px;
}
.features-section {
  position: relative;
  padding: 120px 8%;
  overflow: hidden;
}

.section-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f6f7fb, #eef0ff);
  top: 0;
  left: 0;
  z-index: 0;
}

.features-container {
  position: relative;
  z-index: 2;
  text-align: center;
}

.features-container h2 {
  font-size: 48px;
  font-weight: 800;
  margin-bottom: 15px;
}

.section-subtitle {
  color: #666;
  margin-bottom: 60px;
  font-size: 18px;
}

.features-grid {
  display: flex;
  gap: 40px;
  justify-content: center;
}

.feature-card {
  background: white;
  padding: 45px 35px;
  border-radius: 24px;
  width: 320px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.06);
  transition: 0.35s ease;
}

.feature-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 35px 70px rgba(0,0,0,0.12);
}

.icon {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  margin: 0 auto 25px;
}

.icon.purple {
  background: linear-gradient(135deg, #7b4bb7, #a76be0);
}

.icon.orange {
  background: linear-gradient(135deg, #f4a621, #ffcb52);
}

.icon.blue {
  background: linear-gradient(135deg, #3498db, #6ec1ff);
}

.feature-card h3 {
  margin-bottom: 15px;
  font-size: 20px;
}

.feature-card p {
  color: #666;
  line-height: 1.6;
