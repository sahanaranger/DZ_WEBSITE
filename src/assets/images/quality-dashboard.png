n><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">28</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f4a621;</span><br><span>  border-radius: </span><span class="ͼb">6</span><span class="ͼ8">px</span><span>;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* BUTTONS */</span><br><br><span>.</span><span class="ͼd">odoo-buttons</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">50</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  justify-content: </span><span class="ͼb">center</span><span>;</span><br><span>  gap: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-main</span><span> {</span><br><span>  background: #875A7B;</span><br><span>  color: </span><span class="ͼb">white</span><span>;</span><br><span>  padding: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>  font-size: </span><span class="ͼb">16</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-light</span><span> {</span><br><span>  background: #eceaf3;</span><br><span>  color: #333;</span><br><span>  padding: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>  font-size: </span><span class="ͼb">16</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* SMALL TEXT */</span><br><br><span>.</span><span class="ͼd">price-note</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  font-size: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>  color: #555;</span><br><span>}</span><br><br><span class="ͼ6">/* CURVE EFFECT */</span><br><br><span>.</span><span class="ͼd">hero-curve</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  bottom: </span><span class="ͼb">-120</span><span class="ͼ8">px</span><span>;</span><br><span>  left: </span><span class="ͼb">-10</span><span class="ͼ8">%</span><span>;</span><br><span>  width: </span><span class="ͼb">120</span><span class="ͼ8">%</span><span>;</span><br><span>  height: </span><span class="ͼb">300</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #e9e8ef;</span><br><span>  border-radius: </span><span class="ͼb">50</span><span class="ͼ8">%</span><span> </span><span class="ͼb">50</span><span class="ͼ8">%</span><span> </span><span class="ͼb">0</span><span> </span><span class="ͼb">0</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
