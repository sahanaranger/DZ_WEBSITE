>  { path: </span><span class="ͼc">''</span><span>, redirectTo: </span><span class="ͼc">'home'</span><span>, pathMatch: </span><span class="ͼc">'full'</span><span> },</span><br><br><span>  { path: </span><span class="ͼc">'cm/production-planning'</span><span>, component: </span><span class="ͼe">ProductionPlanningComponent</span><span> },</span><br><span>  { path: </span><span class="ͼc">'cm/quality'</span><span>, component: </span><span class="ͼe">QualityComponent</span><span> },</span><br><span>  { path: </span><span class="ͼc">'cm/warehouse'</span><span>, component: </span><span class="ͼe">WarehouseComponent</span><span> },</span><br><span>  { path: </span><span class="ͼc">'cm/orders'</span><span>, component: </span><span class="ͼe">OrdersComponent</span><span> },</span><br><span>  { path: </span><span class="ͼc">'cm/finance'</span><span>, component: </span><span class="ͼe">FinanceComponent</span><span> },</span><br><span>  { path: </span><span class="ͼc">'cm/multi-plant'</span><span>, component: </span><span class="ͼe">MultiPlantComponent</span><span> }</span><br><br><span>];</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
