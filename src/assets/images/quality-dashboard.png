ard</span><span> {</span><br><span>  background: #f8f9ff;</span><br><span>  padding: </span><span class="ͼb">40</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>  width: </span><span class="ͼb">300</span><span class="ͼ8">px</span><span>;</span><br><span>  transition: </span><span class="ͼb">0.3</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">feature-card</span><span>:</span><span class="ͼd">hover</span><span> {</span><br><span>  transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">-8</span><span class="ͼ8">px</span><span>);</span><br><span>  box-shadow: </span><span class="ͼb">0</span><span> </span><span class="ͼb">15</span><span class="ͼ8">px</span><span> </span><span class="ͼb">40</span><span class="ͼ8">px</span><span> </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0.08</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">icon</span><span> {</span><br><span>  width: </span><span class="ͼb">60</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">60</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">50</span><span class="ͼ8">%</span><span>;</span><br><span>  margin: </span><span class="ͼb">auto</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">icon</span><span>.</span><span class="ͼd">purple</span><span> { background: #7b4bb7; }</span><br><span>.</span><span class="ͼd">icon</span><span>.</span><span class="ͼd">orange</span><span> { background: #f4a621; }</span><br><span>.</