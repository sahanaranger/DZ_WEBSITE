<h2 data-start="1246" data-end="1276">🔹 3. CSS (Real Brush Feel)</h2>
<pre class="overflow-visible! px-0!" data-start="1278" data-end="2674"><div class="relative w-full my-4"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-eri7ssmm.svg#e45ab3" fill="currentColor"></use></svg>CSS</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none size-9 rounded-full px-2 py-2 hover:bg-black/5 dark:hover:bg-white/10" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-eri7ssmm.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>.</span><span class="ͼd">odoo-style-hero</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  padding: </span><span class="ͼb">150</span><span class="ͼ8">px</span><span> </span><span class="ͼb">10</span><span class="ͼ8">%</span><span> </span><span class="ͼb">220</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f7f6fb;</span><br><span>  text-align: </span><span class="ͼb">center</span><span>;</span><br><span>  overflow: </span><span class="ͼb">hidden</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* HANDWRITTEN HEADING */</span><br><br><span>.</span><span class="ͼd">hero-hand</span><span> {</span><br><span>  font-family: </span><span class="ͼc">'Caveat'</span><span>, </span><span class="ͼb">cursive</span><span>;</span><br><span>  font-size: </span><span class="ͼb">72</span><span class="ͼ8">px</span><span>;</span><br><span>  line-height: </span><span class="ͼb">1.15</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">700</span><span>;</span><br><span>  color: #111;</span><br><span>  max-width: </span><span class="ͼb">950</span><span class="ͼ8">px</span><span>;</span><br><span>  margin: </span><span class="ͼb">0</span><span> </span><span class="ͼb">auto</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* PAINT BRUSH EFFECT */</span><br><br><span>.</span><span class="ͼd">paint</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  display: </span><span class="ͼb">inline-block</span><span>;</span><br><span>  z-index: </span><span class="ͼb">1</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">paint</span><span>::</span><span class="ͼd">before</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-15</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-15</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f4a621;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>  transform: </span><span class="ͼ8">rotate</span><span>(</span><span class="ͼb">-1.5</span><span class="ͼ8">deg</span><span>);</span><br><span>}</span><br><br><span class="ͼ6">/* BUTTONS */</span><br><br><span>.</span><span class="ͼd">hero-actions</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">50</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  justify-content: </span><span class="ͼb">center</span><span>;</span><br><span>  gap: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-main</span><span> {</span><br><span>  background: #875A7B;</span><br><span>  color: </span><span class="ͼb">white</span><span>;</span><br><span>  padding: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  font-family: </span><span class="ͼc">'Inter'</span><span>, </span><span class="ͼb">sans-serif</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-light</span><span> {</span><br><span>  background: #e9e7ef;</span><br><span>  color: #333;</span><br><span>  padding: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  font-family: </span><span class="ͼc">'Inter'</span><span>, </span><span class="ͼb">sans-serif</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* SUB NOTE */</span><br><br><span>.</span><span class="ͼd">hero-note</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  font-family: </span><span class="ͼc">'Inter'</span><span>, </span><span class="ͼb">sans-serif</span><span>;</span><br><span>  font-size: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>  color: #555;</span><br><span>}</span><br><br><span class="ͼ6">/* BOTTOM CURVE */</span><br><br><span>.</span><span class="ͼd">bottom-curve</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  bottom: </span><span class="ͼb">-120</span><span class="ͼ8">px</span><span>;</span><br><span>  left: </span><span class="ͼb">-10</span><span class="ͼ8">%</span><span>;</span><br><span>  width: </span><span class="ͼb">120</span><span class="ͼ8">%</span><span>;</span><br><span>  height: </span><span class="ͼb">300</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #e9e8ef;</span><br><span>  border-radius: </span><span class="ͼb">50</span><span class="ͼ8">%</span><span> </span><span class="ͼb">50</span><span class="ͼ8">%</span><span> </span><span class="ͼb">0</span><span> </span><span class="ͼb">0</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
