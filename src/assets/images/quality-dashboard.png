/* ============================= */
/* HEADER */
/* ============================= */

.header-fixed {
  width: 100%;
  background: #ffffff;
  border-bottom: 1px solid #eee;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
}

.navbar {
  max-width: 1300px;
  margin: auto;
  padding: 15px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ============================= */
/* LEFT */
/* ============================= */

.nav-left img {
  height: 42px;
  cursor: pointer;
}

/* ============================= */
/* CENTER */
/* ============================= */

.nav-center {
  display: flex;
  align-items: center;
  gap: 28px;
}

.menu-link {
  font-weight: 600;
  cursor: pointer;
  color: #333;
  text-decoration: none;
  transition: 0.2s ease;
}

.menu-link:hover {
  color: #7b4bb7;
}

/* ============================= */
/* DROPDOWN */
/* ============================= */

.menu-wrapper {
  position: relative;
}

.simple-dropdown {
  position: absolute;
  top: 45px;
  left: 0;
  width: 250px;
  background: #ffffff;
  border-radius: 14px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.08);
  padding-top: 10px;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.2s ease;
}

.simple-dropdown a {
  padding: 12px 20px;
  text-decoration: none;
  color: #333;
  font-weight: 500;
  transition: 0.2s ease;
}

.simple-dropdown a:hover {
  background: #f5f7fa;
  padding-left: 24px;
}

/* CTA Footer */

.dropdown-footer {
  border-top: 1px solid #eee;
  padding: 14px 20px;
  margin-top: 6px;
  background: #fafafa;
}

.dropdown-cta {
  text-decoration: none;
  font-weight: 600;
  color: #7b4bb7;
  display: block;
  transition: 0.2s ease;
}

.dropdown-cta:hover {
  letter-spacing: 0.5px;
}

/* ============================= */
/* RIGHT */
/* ============================= */

.nav-right {
  display: flex;
  align-items: center;
  gap: 18px;
}

.signin-link {
  cursor: pointer;
  font-weight: 500;
}

.demo-btn {
  background: #7b4bb7;
  color: white;
  border: none;
  padding: 10px 18px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.2s ease;
}

.demo-btn:hover {
  background: #6939a8;
}

/* ============================= */
/* ANIMATION */
/* ============================= */

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}




/* ============================= */
/* MEGA MENU FULL WIDTH */
/* ============================= */

.mega-menu {
  width: 100%;
  background: #f4f5f7;
  position: absolute;
  left: 0;
  top: 75px;
  padding: 40px 0 60px;
  border-top: 1px solid #e5e5e5;
  z-index: 999;
}

.mega-container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  justify-content: space-between;
  gap: 40px;
}

/* COLUMN */

.mega-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.mega-col h4 {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 15px;
  position: relative;
}

/* Colored Underlines */

.op::after {
  content: "";
  display: block;
  width: 140px;
  height: 3px;
  background: #20c997;
  margin-top: 6px;
}

.inv::after {
  content: "";
  display: block;
  width: 140px;
  height: 3px;
  background: #8e44ad;
  margin-top: 6px;
}

.bus::after {
  content: "";
  display: block;
  width: 140px;
  height: 3px;
  background: #f39c12;
  margin-top: 6px;
}

.plat::after {
  content: "";
  display: block;
  width: 140px;
  height: 3px;
  background: #3498db;
  margin-top: 6px;
}

/* LINKS */

.mega-col a {
  text-decoration: none;
  color: #333;
  font-weight: 500;
  transition: 0.2s ease;
}

.mega-col a:hover {
  color: #7b4bb7;
}

/* BIG CTA HIGHLIGHT */

.mega-highlight {
  margin-top: 50px;
  text-align: center;
  font-size: 34px;
  font-weight: 800;
  display: inline-block;
  padding: 10px 30px;
  background: linear-gradient(transparent 60%, #f4a621 60%);
  border-radius: 20px;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}
import { Component, HostListener } from '@angular/core';
import { CommonModule } from '@angular/common';
import { Router, RouterLink } from '@angular/router';

@Component({
  selector: 'app-navbar',
  standalone: true,
  imports: [CommonModule, RouterLink],
  templateUrl: './navbar.component.html',
  styleUrls: ['./navbar.component.css']
})
export class NavbarComponent {
 
  showCableMaker: boolean = false;

  isMenuOpen = false;

toggleMenu(event: Event) {
  event.stopPropagation();
  this.isMenuOpen = !this.isMenuOpen;
}

@HostListener('document:click')
closeMenu() {
  this.isMenuOpen = false;
}

