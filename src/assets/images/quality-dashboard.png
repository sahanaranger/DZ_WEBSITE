an>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  z-index: </span><span class="ͼb">1</span><span>;</span><br><span>  color: #111;</span><br><span>}</span><br><br><span class="ͼ6">/* Brush Stroke */</span><br><br><span>.</span><span class="ͼd">mega-highlight-text</span><span>::</span><span class="ͼd">before</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-30</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-30</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">22</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f4a621;</span><br><span>  border-radius: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>  transform: </span><span class="ͼ8">rotate</span><span>(</span><span class="ͼb">-2</span><span class="ͼ8">deg</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">mega-highlight-text</span><span>::</span><span class="ͼd">after</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-25</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-20</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">-4</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">22</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f4a621;</span><br><span>  border-radius: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>  transform: </span><span class="ͼ8">rotate</span><span>(</span><span class="ͼb">2</span><span class="ͼ8">deg</span><span>);</span><br><span>}</span><br><br><span class="ͼ6">/* ================= Animation ================= */</span><br><br><span class="ͼ8">@keyframes</span><span> </span><span class="ͼg">fadeIn</span><span> {</span><br><span>  </span><span class="ͼ8">from</span><span> { opacity: </span><span class="ͼb">0</span><span>; }</span><br><span>  </span><span class="ͼ8">to</span><span> { opacity: </span><span class="ͼb">1</span><span>; }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
