><span>}</span><br><br><span>.</span><span class="ͼd">mega-col</span><span> </span><span class="ͼg">h4</span><span> {</span><br><span>  font-size: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">700</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼb">12</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Colored lines */</span><br><br><span>.</span><span class="ͼd">op</span><span>::</span><span class="ͼd">after</span><span>,</span><br><span>.</span><span class="ͼd">inv</span><span>::</span><span class="ͼd">after</span><span>,</span><br><span>.</span><span class="ͼd">bus</span><span>::</span><span class="ͼd">after</span><span>,</span><br><span>.</span><span class="ͼd">plat</span><span>::</span><span class="ͼd">after</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  display: </span><span class="ͼb">block</span><span>;</span><br><span>  width: </span><span class="ͼb">120</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">3</span><span class="ͼ8">px</span><span>;</span><br><span>  margin-top: </span><span class="ͼb">6</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">op</span><span>::</span><span class="ͼd">after</span><span> { background: #20c997; }</span><br><span>.</span><span class="ͼd">inv</span><span>::</span><span class="ͼd">after</span><span> { background: #8e44ad; }</span><br><span>.</span><span class="ͼd">bus</span><span>::</span><span class="ͼd">after</span><span> { background: #f39c12; }</span><br><span>.</span><span class="ͼd">plat</span><span>::</span><span class="ͼd">after</span><span> { background: #3498db; }</span><br><br><span>.</span><span class="ͼd">mega-col</span><span> </span><span class="ͼg">a</span><span> {</span><br><span>  text-decoration: </span><span class="ͼb">none</span><span>;</span><br><span>  color: #333;</span><br><span>  font-weight: </span><span class="ͼb">500</span><span>;</span><br><span>  font-size: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span>;</span><br><span>  transition: </span><span class="ͼb">0.2</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">mega-col</span><span> </span><span class="ͼg">a</span><span>:</span><span class="ͼd">hover</span><span> {</span><br><span>  color: #7b4bb7;</span><br><span>}</span><br><br><span class="ͼ6">/* BIG HIGHLIGHT */</span><br><br><span>.</span><span class="ͼd">mega-highlight</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">55</span><span class="ͼ8">px</span><span>;</span><br><span>  text-align: </span><span class="ͼb">center</span><span>;</span><br><span>  font-size: </span><span class="ͼb">32</span><span class="ͼ8">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">800</span><span>;</span><br><span>  display: </span><span class="ͼb">inline-block</span><span>;</span><br><span>  padding: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span> </span><span class="ͼb">28</span><span class="ͼ8">px</span><span>;</span><br><span>  background: </span><span class="ͼ8">linear-gradient</span><span>(</span><span class="ͼb">transparent</span><span> </span><span class="ͼb">60</span><span class="ͼ8">%</span><span>, #f4a621 </span><span class="ͼb">60</span><span class="ͼ8">%</span><span>);</span><br><span>  border-radius: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  left: </span><span class="ͼb">50</span><span class="ͼ8">%</span><span>;</span><br><span>  transform: </span><span class="ͼ8">translateX</span><span>(</span><span class="ͼb">-50</span><span class="ͼ8">%</span><span>);</span><br><span>}</span><br><br><span class="ͼ6">/* Animation */</span><br><br><span class="ͼ8">@keyframes</span><span> </span><span class="ͼg">fadeIn</span><span> {</span><br><span>  </span><span class="ͼ8">from</span><span> { opacity: </span><span class="ͼb">0</span><span>; transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">-8</span><span class="ͼ8">px</span><span>); }</span><br><span>  </span><span class="ͼ8">to</span><span> { opacity: </span><span class="ͼb">1</span><span>; transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">0</span><span>); }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
