dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼ6">/* =========================</span><br><span class="ͼ6">   HERO SECTION</span><br><span class="ͼ6">========================= */</span><br><br><span>.</span><span class="ͼd">qa-hero-odoo-style</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  padding: </span><span class="ͼb">180</span><span class="ͼ8">px</span><span> </span><span class="ͼb">10</span><span class="ͼ8">%</span><span> </span><span class="ͼb">160</span><span class="ͼ8">px</span><span>;</span><br><span>  text-align: </span><span class="ͼb">center</span><span>;</span><br><span>  background: #fafafa;</span><br><span>  overflow: </span><span class="ͼb">hidden</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Background Blob */</span><br><br><span>.</span><span class="ͼd">bg-blob</span><span> {</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  width: </span><span class="ͼb">600</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">600</span><span class="ͼ8">px</span><span>;</span><br><span>  background: </span><span class="ͼ8">radial-gradient</span><span>(</span><span class="ͼb">circle</span><span> </span><span class="ͼb">at</span><span> </span><span class="ͼb">center</span><span>, #e9e7ff, </span><span class="ͼb">transparent</span><span> </span><span class="ͼb">70</span><span class="ͼ8">%</span><span>);</span><br><span>  top: </span><span class="ͼb">-200</span><span class="ͼ8">px</span><span>;</span><br><span>  left: </span><span class="ͼb">50</span><span class="ͼ8">%</span><span>;</span><br><span>  transform: </span><span class="ͼ8">translateX</span><span>(</span><span class="ͼb">-50</span><span class="ͼ8">%</span><span>);</span><br><span>  z-index: </span><span class="ͼb">0</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Container */</span><br><br><span>.</span><span class="ͼd">qa-container</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  z-index: </span><span class="ͼb">2</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Title */</span><br><br><span>.</span><span class="ͼd">hero-title</span><span> {</span><br><span>  font-size: </span><span class="ͼb">72</span><span class="ͼ8">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">800</span><span>;</span><br><span>  line-height: </span><span class="ͼb">1.1</span><span>;</span><br><span>  color: #1f1f1f;</span><br><span>  letter-spacing: </span><span class="ͼb">-1</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Highlight Brush */</span><br><br><span>.</span><span class="ͼd">highlight-text</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>  display: </span><span class="ͼb">inline-block</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">highlight-text</span><span>::</span><span class="ͼd">before</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">24</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #ffd54f;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">6</span><span class="ͼ8">px</span><span>;</span><br><span>  transform: </span><span class="ͼ8">rotate</span><span>(</span><span class="ͼb">-1.5</span><span class="ͼ8">deg</span><span>);</span><br><span>}</span><br><br><span class="ͼ6">/* Subtitle */</span><br><br><span>.</span><span class="ͼd">hero-subtitle</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  font-size: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>  color: #555;</span><br><span>  max-width: </span><span class="ͼb">750</span><span class="ͼ8">px</span><span>;</span><br><span>  margin-left: </span><span class="ͼb">auto</span><span>;</span><br><span>  margin-right: </span><span class="ͼb">auto</span><span>;</span><br><span>  line-height: </span><span class="ͼb">1.6</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Buttons */</span><br><br><span>.</span><span class="ͼd">hero-buttons</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">50</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  justify-content: </span><span class="ͼb">center</span><span>;</span><br><span>  gap: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-primary</span><span> {</span><br><span>  background: #6d5dfc;</span><br><span>  color: </span><span class="ͼb">white</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  padding: </span><span class="ͼb">16</span><span class="ͼ8">px</span><span> </span><span class="ͼb">36</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>  cursor: </span><span class="ͼb">pointer</span><span>;</span><br><span>  transition: </span><span class="ͼb">0.3</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-primary</span><span>:</span><span class="ͼd">hover</span><span> {</span><br><span>  transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">-3</span><span class="ͼ8">px</span><span>);</span><br><span>  box-shadow: </span><span class="ͼb">0</span><span> </span><span class="ͼb">12</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span> </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">109</span><span>,</span><span class="ͼb">93</span><span>,</span><span class="ͼb">252</span><span>,</span><span class="ͼb">0.3</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-secondary</span><span> {</span><br><span>  background: #f1f1f1;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  padding: </span><span class="ͼb">16</span><span class="ͼ8">px</span><span> </span><span class="ͼb">36</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>  cursor: </span><span class="ͼb">pointer</span><span>;</span><br><span>  transition: </span><span class="ͼb">0.3</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-secondary</span><span>:</span><span class="ͼd">hover</span><span> {</span><br><span>  background: #e6e6e6;</span><br><span>}</span><br><br><span class="ͼ6">/* Floating Note */</span><br><br><span>.</span><span class="ͼd">floating-note</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">60</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">inline-block</span><span>;</span><br><span>  background: </span><span class="ͼb">white</span><span>;</span><br><span>  padding: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">12</span><span class="ͼ8">px</span><span>;</span><br><span>  font-size: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span>;</span><br><span>  color: #444;</span><br><span>  box-shadow: </span><span class="ͼb">0</span><span> </span><span class="ͼb">20</span><span class="ͼ8">px</span><span> </span><span class="ͼb">50</span><span class="ͼ8">px</span><span> </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0.08</span><span>);</span><br><span>  animation: </span><span class="ͼb">floatNote</span><span> </span><span class="ͼb">4</span><span class="ͼ8">s</span><span> </span><span class="ͼb">ease-in-out</span><span> </span><span class="ͼb">infinite</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Floating animation */</span><br><br><span class="ͼ8">@keyframes</span><span> </span><span class="ͼg">floatNote</span><span> {</span><br><span>  </span><span class="ͼb">0</span><span class="ͼ8">%</span><span> { transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">0</span><span class="ͼ8">px</span><span>); }</span><br><span>  </span><span class="ͼb">50</span><span class="ͼ8">%</span><span> { transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">-8</span><span class="ͼ8">px</span><span>); }</span><br><span>  </span><span class="ͼb">100</span><span class="ͼ8">%</span><span> { transform: </span><span class="ͼ8">translateY</span><span>(</span><span class="ͼb">0</span><span class="ͼ8">px</span><span>); }</span><br><span>}</span><br><br><span class="ͼ6">/* =========================</span><br><span class="ͼ6">   RESPONSIVE</span><br><span class="ͼ6">========================= */</span><br><br><span class="ͼ8">@media</span><span> (max-width: </span><span class="ͼb">992</span><span class="ͼ8">px</span><span>) {</span><br><span>  .</span><span class="ͼd">hero-title</span><span> {</span><br><span>    font-size: </span><span class="ͼb">48</span><span class="ͼ8">px</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">hero-subtitle</span><span> {</span><br><span>    font-size: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">hero-buttons</span><span> {</span><br><span>    flex-direction: </span><span class="ͼb">column</span><span>;</span><br><span>  }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
