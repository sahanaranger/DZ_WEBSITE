pan>  color: #555;</span><br><span>  line-height: </span><span class="ͼb">1.6</span><span>;</span><br><span>  max-width: </span><span class="ͼb">600</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-primary</span><span> {</span><br><span>  background: #6d5dfc;</span><br><span>  color: </span><span class="ͼb">white</span><span>;</span><br><span>  padding: </span><span class="ͼb">14</span><span class="ͼ8">px</span><span> </span><span class="ͼb">30</span><span class="ͼ8">px</span><span>;</span><br><span>  border-radius: </span><span class="ͼb">6</span><span class="ͼ8">px</span><span>;</span><br><span>  border: </span><span class="ͼb">none</span><span>;</span><br><span>  font-weight: </span><span class="ͼb">600</span><span>;</span><br><span>  cursor: </span><span class="ͼb">pointer</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* Right visual minimal */</span><br><br><span>.</span><span class="ͼd">qa-hero-right</span><span> {</span><br><span>  position: </span><span class="ͼb">relative</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">quality-block</span><span> {</span><br><span>  height: </span><span class="ͼb">280</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f3f4ff;</span><br><span>  border-radius: </span><span class="ͼb">8</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">quality-line</span><span> {</span><br><span>  width: </span><span class="ͼb">4</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">200</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #6d5dfc;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  right: </span><span class="ͼb">-20</span><span class="ͼ8">px</span><span>;</span><br><span>  top: </span><span class="ͼb">40</span><span class="ͼ8">px</span><span>;</span><br><span>}<