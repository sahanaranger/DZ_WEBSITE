: </span><span class="ͼb">0</span><span> </span><span class="ͼb">25</span><span class="ͼ8">px</span><span> </span><span class="ͼb">50</span><span class="ͼ8">px</span><span> </span><span class="ͼ8">rgba</span><span>(</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0</span><span>,</span><span class="ͼb">0.1</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">feature-card</span><span>.</span><span class="ͼd">purple</span><span> {</span><br><span>  background: #f2eafd;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">feature-card</span><span>.</span><span class="ͼd">orange</span><span> {</span><br><span>  background: #fff3e0;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">feature-card</span><span> </span><span class="ͼg">h3</span><span> {</span><br><span>  margin-bottom: </span><span class="ͼb">15</span><span class="ͼ8">px</span><span>;</span><br><span>  font-size: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">feature-card</span><span> </span><span class="ͼg">p</span><span> {</span><br><span>  color: #555;</span><br><span>  line-height: </span><span class="ͼb">1.6</span><span>;</span><br><span>}</span><br><br><span class="ͼ6">/* ================= RESPONSIVE ================= */</span><br><br><span class="ͼ8">@media</span><span> (max-width: </span><span class="ͼb">1024</span><span class="ͼ8">px</span><span>) {</span><br><span>  .</span><span class="ͼd">hero-section</span><span> {</span><br><span>    flex-direction: </span><span class="ͼb">column</span><span>;</span><br><span>    text-align: </span><span class="ͼb">center</span><span>;</span><br><span>  }</span><br><br><span>  .</span><span class="ͼd">hero-right</span><span> </span><span class="ͼg">img</span><span> {</span><br><span>    width: </span><span class="ͼb">100</span><span class="ͼ8">%</span><span>;</span><br><span>    mar