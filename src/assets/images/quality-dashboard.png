ne-block</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">highlight</span><span>::</span><span class="ͼd">before</span><span> {</span><br><span>  content: </span><span class="ͼc">""</span><span>;</span><br><span>  position: </span><span class="ͼb">absolute</span><span>;</span><br><span>  left: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  right: </span><span class="ͼb">-10</span><span class="ͼ8">px</span><span>;</span><br><span>  bottom: </span><span class="ͼb">10</span><span class="ͼ8">px</span><span>;</span><br><span>  height: </span><span class="ͼb">22</span><span class="ͼ8">px</span><span>;</span><br><span>  background: #f4a621;</span><br><span>  border-radius: </span><span class="ͼb">20</span><span class="ͼ8">px</span><span>;</span><br><span>  z-index: </span><span class="ͼb">-1</span><span>;</span><br><span>  transform: </span><span class="ͼ8">rotate</span><span>(</span><span class="ͼb">-2</span><span class="ͼ8">deg</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼd">hero-subtitle</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">25</span><span class="ͼ8">px</span><span>;</span><br><span>  font-size: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>  color: #555;</span><br><span>  line-height: </span><span class="ͼb">1.6</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">hero-buttons</span><span> {</span><br><span>  margin-top: </span><span class="ͼb">35</span><span class="ͼ8">px</span><span>;</span><br><span>  display: </span><span class="ͼb">flex</span><span>;</span><br><span>  gap: </span><span class="ͼb">18</span><span class="ͼ8">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼd">btn-primary</span><span> {</span><br><span>  background: #7b4bb7;</span><br><span>  color: </span><span class="ͼb">white</span><span>;</span><br><span>  border: </span><span class="